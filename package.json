{
  "name": "nuxt-date-fns",
  "version": "1.1.0",
  "description": "Nuxt module for date-fns",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gficher/nuxt-date-fns.git"
  },
  "license": "MIT",
  "author": "Gustavo Ficher <[EMAIL_ADDRESS]>",
  "homepage": "https://github.com/gficher/nuxt-date-fns",
  "bugs": {
    "url": "https://github.com/gficher/nuxt-date-fns/issues"
  },
  "type": "module",
  "keywords": [
    "vue",
    "vuejs",
    "nuxt",
    "nuxt3",
    "nuxt4",
    "date-fns",
    "date",
    "datetime",
    "time",
    "format",
    "parse"
  ],
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "peerDependencies": {
    "date-fns": "^3.0.0 || ^4.0.0"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.8"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.8",
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "latest",
    "changelogen": "^0.6.2",
    "date-fns": "^4.4.0",
    "eslint": "^10.4.1",
    "nuxt": "^4.4.8",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.3"
  }
}
